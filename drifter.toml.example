# drifter.toml — the only file you edit

[llm]
provider = "openrouter"
model = "openrouter/qwen/qwen3.6-plus:free"  # change as needed — any OpenRouter model works
api_key = "YOUR_KEY_HERE"          # OpenRouter API key

[notify]
# Uncomment to get birth/death notifications on your phone
# Install ntfy app, subscribe to your topic
# topic = "drifter-approvals"

[dashboard]
# password = "changeme"           # leave commented for open access
port = 8080
