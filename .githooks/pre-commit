#!/usr/bin/env bash
# Prevent agents from committing directly to main.
# Agents must create agent/<n>/<topic> branches for auto-merge.

if [ -n "${DRIFTER_AGENT:-}" ]; then
  branch=$(git rev-parse --abbrev-ref HEAD)
  if [ "$branch" = "main" ]; then
    echo "ERROR: Agent '$DRIFTER_AGENT' cannot commit to main directly." >&2
    echo "Create a branch: git checkout -b agent/<name>/<topic>" >&2
    exit 1
  fi
fi
